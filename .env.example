# Google Cloud Project Configuration
PROJECT_ID=your-project-id
LOCATION=us-central1

# Authentication (required for Vertex AI)
# Option 1: Place service-account-key.json in the project root (no env var needed).
# Option 2: Set SERVICE_ACCOUNT_KEY_PATH to your key file path (e.g. ../keys/my-key.json).
# Option 3: Set GOOGLE_APPLICATION_CREDENTIALS to the absolute path of your key file.
# SERVICE_ACCOUNT_KEY_PATH=       

# Database: use ONE of the following.
#
# Option A - PostgreSQL (recommended for Render / Railway)
#
# --- Only variable you need to change when swapping databases ---
# Paste the full connection string from Render → PostgreSQL → Connect.
#   • On your PC (npm start): use External Database URL + append ?sslmode=require
#   • On Render Web Service: use Internal Database URL (or link DB so Render sets DATABASE_URL)
#
# After each NEW free Postgres instance: run database/schema.pg.sql once in that database.
# If the users table is empty, the app creates superadmin@zaha.ai (password: admin123) on startup.
#
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
#
# Option B - MySQL (e.g. PlanetScale, or local)
# Leave DATABASE_URL unset and set these instead.
# DB_HOST=localhost
# DB_USER=your_user
# DB_PASSWORD=your_password
# DB_NAME=your_database

# Session secret (change in production)
SESSION_SECRET=your-random-secret-key

